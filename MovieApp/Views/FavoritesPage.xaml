<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MovieApp.Models"
             x:Class="MovieApp.Views.FavoritesPage"
             Title="Favorites">

    <Grid RowDefinitions="*,Auto">

        <CollectionView Grid.Row="0"
                        x:Name="FavoritesCollection"
                        Margin="10">
            <CollectionView.EmptyView>
                <Label Text="No favorites yet. Add some movies!" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"
                       TextColor="Gray"
                       Margin="20"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Movie">
                    <Border Margin="0,5" Padding="15" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0">
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Genre}" FontSize="13" TextColor="Gray"/>
                                <Label Text="{Binding Year}" FontSize="13" TextColor="Gray"/>
                                <Label Text="{Binding AverageRating, StringFormat='⭐ {0:F1}'}" FontSize="13"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="Remove"
                                    TextColor="Red"
                                    BackgroundColor="Transparent"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnRemoveFavoriteClicked"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>