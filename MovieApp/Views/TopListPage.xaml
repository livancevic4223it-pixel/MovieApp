<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MovieApp.Models"
             x:Class="MovieApp.Views.TopListPage"
             Title="Top Movies">

    <CollectionView x:Name="TopMoviesCollection" Margin="10">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:Movie">
                <Border Margin="0,5" Padding="15" StrokeShape="RoundRectangle 10">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0"
                               x:Name="RankLabel"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="Gold"
                               VerticalOptions="Center"
                               Margin="0,0,15,0"/>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold"/>
                            <Label Text="{Binding Genre}" FontSize="13" TextColor="Gray"/>
                            <Label Text="{Binding AverageRating, StringFormat='⭐ {0:F1} / 5'}" FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>