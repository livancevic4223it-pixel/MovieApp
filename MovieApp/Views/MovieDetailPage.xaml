<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MovieApp.Views.MovieDetailPage"
             Title="Movie Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Image x:Name="MovieImage"
                   HeightRequest="250"
                   Aspect="AspectFill"
                   IsVisible="False"/>

            <Label x:Name="TitleLabel" FontSize="24" FontAttributes="Bold"/>
            <Label x:Name="GenreYearLabel" FontSize="14" TextColor="Gray"/>
            <Label x:Name="DescriptionLabel" FontSize="14" Margin="0,10"/>

            <Label Text="Cast" FontAttributes="Bold" FontSize="16"/>
            <Label x:Name="CastLabel" FontSize="14" TextColor="Gray"/>

            <Label Text="Your Rating" FontAttributes="Bold" FontSize="16" Margin="0,15,0,0"/>

            <HorizontalStackLayout x:Name="StarContainer" Spacing="5">
                <Label Text="★" FontSize="36" x:Name="Star1">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="★" FontSize="36" x:Name="Star2">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="★" FontSize="36" x:Name="Star3">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="★" FontSize="36" x:Name="Star4">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                    </Label.GestureRecognizers>
                </Label>
                <Label Text="★" FontSize="36" x:Name="Star5">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Label x:Name="RatingLabel" FontSize="14" TextColor="Gray"/>

            <Grid ColumnDefinitions="*,*" Margin="0,20,0,0" ColumnSpacing="10">
                <Button Grid.Column="0"
                        x:Name="FavoriteButton"
                        Text="Add to Favorites"
                        Clicked="OnFavoriteClicked"/>
                <Button Grid.Column="1"
                        Text="Edit"
                        Clicked="OnEditClicked"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>