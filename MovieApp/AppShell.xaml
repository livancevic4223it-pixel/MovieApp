<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:MovieApp.Views"
       x:Class="MovieApp.AppShell">

    <TabBar>
        <Tab Title="Movies" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="main"/>
        </Tab>
        <Tab Title="Favorites" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:FavoritesPage}" Route="favorites"/>
        </Tab>
        <Tab Title="Top List" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:TopListPage}" Route="toplist"/>
        </Tab>
        <Tab Title="Reminder" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate views:ReminderPage}" Route="reminder"/>
        </Tab>
    </TabBar>

</Shell>